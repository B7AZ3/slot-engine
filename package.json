{
  "name": "slot-engine",
  "version": "1.0.0",
  "description": "A generic, modern slot game engine",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "fontfaceobserver": "^2.3.0",
    "gsap": "^3.12.5",
    "howler": "^2.2.4",
    "pixi.js": "^8.4.0"
  },
  "peerDependencies": {
    "pixi.js": "^7.0.0 || ^8.0.0",
    "gsap": "^3.0.0",
    "howler": "^2.0.0",
    "fontfaceobserver": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "pixi.js": { "optional": false },
    "gsap": { "optional": false },
    "howler": { "optional": false },
    "fontfaceobserver": { "optional": true }
  },
  "devDependencies": {
    "@types/fontfaceobserver": "^2.1.3",
    "@types/howler": "^2.2.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
